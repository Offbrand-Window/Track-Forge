PORT=5173

# Optional paths when yt-dlp/youtube-dl or ffmpeg are not on PATH:
# YTDLP_PATH=/path/to/yt-dlp
# YOUTUBE_DL_PATH=/path/to/youtube-dl
# FFMPEG_PATH=/path/to/ffmpeg

# Maximum accepted media duration in seconds for local media imports:
MEDIA_IMPORT_MAX_SECONDS=1800

# Optional workaround for local certificate-store problems in yt-dlp.
# Only use this for sources you trust.
# YTDLP_NO_CHECK_CERTIFICATE=1
